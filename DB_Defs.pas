DDL: '^CUSTAGREEMENT_AFTER_UPDATE^,^CREATE TRIGGER `CUSTAGREEMENT_AFTER_UPDATE` AFTER UPDATE ON `CUSTAGREEMENT` FOR EACH ROW' + #10 +
'BEGIN' + #10 +
'  DECLARE m_change TEXT DEFAULT '''';' + #10 +
'  DECLARE strUser TEXT DEFAULT '''';' + #10 +
'  SET strUser = @APPUSERNAME ;' + #10 +
'  -- Check and log changes to STATUS' + #10 +
'  IF COALESCE(NEW.STATUS, '''') != COALESCE(OLD.STATUS, '''') THEN' + #10 +
'    SET m_change = CONCAT(m_change, IF(m_change != '''', '', '', ''''), ''Previous Status: '', COALESCE(OLD.STATUS, ''NULL''), '' -> New Status: '', COALESCE(NEW.STATUS, ''NULL''));' + #10 +
'  END IF;' + #10 +
'  -- Check and log changes to SERVICE' + #10 +
'  IF COALESCE(NEW.SERVICE, '''') != COALESCE(OLD.SERVICE, '''') THEN' + #10 +
'    SET m_change = CONCAT(m_change, IF(m_change != '''', '', '', ''''), ''Previous Service: '', COALESCE(OLD.SERVICE, ''NULL''), '' -> New Service: '', COALESCE(NEW.SERVICE, ''NULL''));' + #10 +
'  END IF;' + #10 +
'  -- Check and log changes to BOOKEDDATE' + #10 +
'  -- IF COALESCE(NEW.BOOKEDDATE, '''') != COALESCE(OLD.BOOKEDDATE, '''') THEN' + #10 +
'  --     SET m_change = CONCAT(m_change, IF(m_change != '''', '', '', ''''), ''Previous Booked: '', COALESCE(OLD.BOOKEDDATE, ''NULL''), '' -> New Booked: '', BOOKEDDATE(NEW.BOOKEDDATE, ''NULL''));' + #10 +
'  -- END IF;' + #10 +
'  -- Check and log changes to CUSTOMERID' + #10 +
'  IF COALESCE(NEW.CUSTOMERID, '''') != COALESCE(OLD.CUSTOMERID, '''') THEN' + #10 +
'    SET m_change = CONCAT(m_change, IF(m_change != '''', '', '', ''''), ''Previous Customer ID: '', COALESCE(OLD.CUSTOMERID, ''NULL''), '' -> New Customer ID: '', COALESCE(NEW.CUSTOMERID, ''NULL''));' + #10 +
'  END IF;' + #10 +
'  IF m_change > '''' THEN' + #10 +
'    insert into logging.SYSTEMLOG(LOGUSER,LOGDATE,LOGDETAILS,LOGREF,LOGTABLE, LOGAPP, LOGPC, LOGMODULE)' + #10 +
'    values (strUser,now(), m_change, OLD.AGREEMENTID,''CUSTAGREEMENT'' ,@APPNAME, @APPPCNAME,@APPMODULE) ;' + #10 +
'  END IF ;' + #10 +
'END^,^CUSTAGREEMENT_AFTER_UPDATE^~';),


